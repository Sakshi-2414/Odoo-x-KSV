# Copy this file to .env.local and fill in real values. DO NOT commit your secrets.

# Public (client) Supabase values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server (admin) Supabase values - keep secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Resend (email) API key
RESEND_API_KEY=your-resend-api-key

# Optional: AI / LLM keys
# e.g. for OpenAI / Gemini / Claude connectors used by lib/gemini.ts
OPENAI_API_KEY=your-openai-key
GEMINI_API_KEY=your-gemini-key

# Optional: Next.js runtime settings
NEXT_PUBLIC_APP_NAME=Odoo-x-KSV
